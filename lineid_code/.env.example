# ===== LINE 帳號綁定系統 - 環境變數 =====

# Postgres 連線字串（使用 Connection Pooler，port 6543）
# 從 Supabase Dashboard → Connection Pooling 取得
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres

# 是否啟用 SSL（Zeabur 容器環境建議設為 true）
DB_SSL=false

# 加密金鑰（32 bytes, base64，可透過 node -e "console.log(require('crypto').randomBytes(32).toString('base64'))" 產生）
APP_KEY_V1=YOUR_BASE64_32BYTE_KEY

# 目前使用的金鑰版本
APP_KEY_CURRENT_VERSION=1

# /api/cleanup 授權金鑰（需與 GitHub Secrets 中的 CLEANUP_API_KEY 一致）
CLEANUP_API_KEY=MsFn4rMxHiHCJyoedAhLcw43k4Ia64DtwYGKUmTbRV0=

# 驗證碼有效期（分鐘）
VERIFY_CODE_TTL_MINUTES=5

# 錯誤次數上限
VERIFY_MAX_ATTEMPTS=3

# ===== LINE Messaging API（LINE Webhook 用）=====
# 從 LINE Developers Console → 你的 Messaging API 頻道取得
LINE_CHANNEL_SECRET=YOUR_CHANNEL_SECRET
LINE_CHANNEL_ACCESS_TOKEN=YOUR_CHANNEL_ACCESS_TOKEN

# API 基地 URL（供 line-webhook 內部呼叫 /api/verify）
API_BASE_URL=https://lineid-code.zeabur.app

# 服務埠號（Zeabur 部署時平台會注入，無需在環境變數頁設定）
PORT=8081