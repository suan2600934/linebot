# ===== LINE 帳號綁定系統 - 環境變數 =====

# Postgres 連線字串（Zeabur 內建，若需要自己填）
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== 加密金鑰（32 bytes, base64 編碼）=====
# 產生方式：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEY_V1=your_base64_32bytes_key_here

# 金鑰輪替用（選填，初期先留空）
# APP_KEY_V2=your_second_version_key_here

# 目前使用的金鑰版本（預設 1）
APP_KEY_CURRENT_VERSION=1

# ===== API 設定 =====
# /api/cleanup 授權金鑰（自己訂一個隨機字串）
CLEANUP_API_KEY=your_random_cleanup_key_here

# 驗證碼有效期（分鐘），預設 5
VERIFY_CODE_TTL_MINUTES=5

# 錯誤次數上限，預設 3
VERIFY_MAX_ATTEMPTS=3

# 服務埠號，預設 3000（Zeabur 通常自動設定 PORT）
PORT=3000