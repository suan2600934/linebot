# 賜安診所 LINE Bot 顏色設定
# 最後更新：2026-06-17

## 醫師顏色
doctor_colors:
  周見成: '#3498DB'  # 藍色
  鄭名傑: '#E74C3C'  # 紅色
  石逸仁: '#27AE60'  # 綠色

## Rich Menu 背景色（馬卡龍色系）
richmenu_colors:
  左上_診所藥局: '#A8D8EA'  # 馬卡龍藍
  右上_醫師介紹: '#FFB7B2'  # 馬卡龍粉
  左下_醫師門診表: '#B5EAD7'  # 馬卡龍綠
  右下_分享LINE: '#E2C7F0'  # 馬卡龍紫

## 班表圖片背景色
schedule_colors:
  標題背景: '#2C5F7C'  # 深藍色
  欄位背景: '#A8D8EA'  # 淺藍色
  早診背景: '#FFF5EE'  # 淡淡的粉
  午診背景: '#F0FFFF'  # 淡淡的青
  晚診背景: '#F0FFF0'  # 淡淡的綠

## 文字顏色
text_colors:
  標題: '#2C5F7C'  # 深藍色
  內文: '#333333'  # 深灰
  白色: '#FFFFFF'  # 白色